# ---- Glowbloom backend environment ----
# Copy this file to ".env" and fill in your values. Never commit ".env".

# Postgres connection string (your online database).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/glowbloom?schema=public"

# Port the API listens on locally.
PORT=4000

# Secret used to sign session JWTs. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-secret"

# Allowed origins for CORS (comma-separated). "*" is fine for local dev.
CORS_ORIGIN="*"

# When true, OTP/verification codes are returned in API responses for local
# testing instead of being sent by email/SMS. NEVER enable in production.
DEV_RETURN_CODES=true

# ---- Microsoft Graph (email OTP) ----
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-app-client-id
GRAPH_CLIENT_SECRET=your-client-secret
GRAPH_SENDER=no-reply@yourdomain.com

# Set to "production" on AWS so OTP codes are emailed via Graph (never returned in API).
NODE_ENV=development

# ---- Admin module login ----
ADMIN_EMAIL=admin@niytri.com
ADMIN_PASSWORD=change-me-strong-admin-password

# ---- Email provider ----
# "ses" = Amazon SES (fast transactional, recommended), "graph" = Microsoft 365.
EMAIL_PROVIDER=graph
OTP_TTL_MIN=5
PUBLIC_BASE_URL=https://glowbloom.treeantstechnologies.com

# ---- Amazon SES ----
SES_REGION=ap-south-1
SES_FROM=no-reply@niytri.com
# Credentials come from the EC2 instance IAM role (preferred). For local dev you
# can instead set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.

# ---- Google Sign-In (web) ----
GOOGLE_CLIENT_ID=318258264454-k63f3lnpmio66dv3eu7g0irvjljf1du7.apps.googleusercontent.com
